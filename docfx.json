{
  "build": {
    "content": [
      {
        "files": ["docs/**.md", "docs/**/toc.yml", "index.md"]
      }
    ],
    "resource": [
      {
        "files": ["docs/images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "VibeVault",
      "_appFooter": "VibeVault - Containerized integration testing for RocketMod plugins",
      "_enableSearch": true
    }
  }
}
