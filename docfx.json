{
  "build": {
    "content": [
      {
        "files": [
          "docs/**.md",
          "docs/**/toc.yml",
          "index.md",
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": ["docs/images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "VibePlugins",
      "_appName": "VibePlugins",
      "_appFooter": "&copy; 2026 VibePlugins. Built with <a href=\"https://dotnet.github.io/docfx\">DocFX</a>.",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/esozb/vibevault",
        "branch": "main"
      },
      "pdf": false
    },
    "markdownEngineProperties": {
      "alerts": {
        "TODO": "alert alert-secondary"
      }
    }
  }
}
